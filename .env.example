# Formspree forms - create at https://formspree.io
# Demo form: captures name, email, phone, business type, etc.
NEXT_PUBLIC_FORMSPREE_DEMO_ENDPOINT=https://formspree.io/f/YOUR_DEMO_FORM_ID

# Calendly embed for dentists landing (e.g. https://calendly.com/your-link?embed_domain=...)
# If set, Book Demo CTA shows Calendly iframe instead of form.
# NEXT_PUBLIC_CALENDLY_EMBED_URL=

# Feedback form: for error/404 page "$1B idea" submissions
NEXT_PUBLIC_FORMSPREE_FEEDBACK_ENDPOINT=https://formspree.io/f/YOUR_FEEDBACK_FORM_ID
